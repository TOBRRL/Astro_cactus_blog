---
// src/components/CRTOverlay.astro
---
<div class="crt-wrapper" aria-hidden="true">
  {/* 手动生成 250 条线，覆盖大部分屏幕高度 */}
  {Array.from({ length: 250 }).map((_, i) => (
    <div class="line" style={`top: ${i * 4}px`}></div>
  ))}
</div>

<style is:global>
  .crt-wrapper {
    position: fixed !important;
    inset: 0 !important;
    z-index: 999999 !important;
    pointer-events: none !important;
    overflow: hidden !important;
  }

  .line {
    position: absolute !important;
    left: 0 !important;
    width: 100% !important;
    height: 1px !important;
    background-color: rgba(0, 255, 0, 0.15) !important;
    /* 这里的动画只负责位移 4px，绝对不会产生幽灵方块 */
    animation: line-move 0.5s linear infinite !important;
  }

  @keyframes line-move {
    from { transform: translateY(0); }
    to { transform: translateY(4px); }
  }
</style>
